# Anamnesis — server-side .env for the TrueNAS deployment.
# Place at /mnt/ssd/apps/anamnesis/config/anamnesis.env (mode 600, owner 568:568).
# Generate each token with: openssl rand -hex 32

APP_PIN=123456

API_TOKEN=
ADMIN_TOKEN=
SESSION_SECRET=

# Match the domain you publish through Nginx Proxy Manager
CORS_ORIGINS=https://anamnesis.wndw.co.uk
WEBAUTHN_RP_ID=anamnesis.wndw.co.uk
WEBAUTHN_RP_NAME=Anamnesis
WEBAUTHN_ORIGIN=https://anamnesis.wndw.co.uk

BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=6
BACKUP_KEEP_COUNT=14
BACKUP_ENCRYPTION_KEY=

# Optional offsite backup channel
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── v4.0 multi-user ───────────────────────────────────────
# First admin user (one-time backfill). When users table is empty AND
# patient(id=1) exists, the backend creates an admin user linked to
# patient_id=1 on next start. Login form is at /login (email + password).
# Remove these vars after the first successful backfill — the hash lives
# in the database from then on.
ANAMNESIS_ADMIN_EMAIL=
ANAMNESIS_ADMIN_PASSWORD=

# ─── Cloudflare Access (optional outer auth gate) ──────────
# Enable to require CF Access JWT on every request. Friends-only
# whitelist by email becomes a network-edge concern; in-app login still
# happens. Without these set, the middleware is a pass-through.
#   1. Cloudflare Zero Trust → Access → Applications → Self-hosted
#   2. Application domain: anamnesis.wndw.co.uk
#   3. Identity providers: Google / email OTP / GitHub / …
#   4. Policies → Include → Emails → list of friends
#   5. Copy from the application overview:
#        - Audience (AUD) tag → CF_ACCESS_AUD
#        - Team domain → CF_ACCESS_TEAM_DOMAIN (without https://)
# Also required: /api/auth/register only accepts requests with a valid
# Cf-Access-Jwt-Assertion (CF off → no registration possible).
CF_ACCESS_TEAM_DOMAIN=
CF_ACCESS_AUD=
