# Anamnesis — server-side .env (v4.1 Google-only via CF Access).
# Place at /mnt/ssd/apps/anamnesis/config/anamnesis.env (mode 600, owner 568:568).
# Generate each token with: openssl rand -hex 32

API_TOKEN=
ADMIN_TOKEN=
SESSION_SECRET=

# Домен публикуемый через CF Tunnel (для CORS — но при Tunnel это same-origin)
CORS_ORIGINS=https://health.dcccxii.com

BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=6
BACKUP_KEEP_COUNT=14
BACKUP_ENCRYPTION_KEY=

# Optional offsite backup channel
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Auth (v4.1) ────────────────────────────────────────────
# Email который получает role='admin' и ai_enabled=1 при первом
# CF-Access bootstrap. Все остальные email-ы создаются как обычные user.
ANAMNESIS_ADMIN_EMAIL=kriulin@proton.me

# ─── Cloudflare Access (требуется в v4.1) ──────────────────
# Без CF Access auth не работает — backend не сможет идентифицировать
# юзера. Заполняется значениями из Zero Trust → Access → Applications:
#   - CF_ACCESS_TEAM_DOMAIN: <team>.cloudflareaccess.com (без https://)
#   - CF_ACCESS_AUD: hex Application Audience tag (~64 chars)
CF_ACCESS_TEAM_DOMAIN=
CF_ACCESS_AUD=
