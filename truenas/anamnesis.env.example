# Anamnesis — server-side .env for the TrueNAS deployment.
# Place at /mnt/ssd/apps/anamnesis/config/anamnesis.env (mode 600, owner 568:568).
# Generate each token with: openssl rand -hex 32

APP_PIN=123456

API_TOKEN=
ADMIN_TOKEN=
SESSION_SECRET=

# Match the domain you publish through Nginx Proxy Manager
CORS_ORIGINS=https://anamnesis.wndw.co.uk
WEBAUTHN_RP_ID=anamnesis.wndw.co.uk
WEBAUTHN_RP_NAME=Anamnesis
WEBAUTHN_ORIGIN=https://anamnesis.wndw.co.uk

BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=6
BACKUP_KEEP_COUNT=14
BACKUP_ENCRYPTION_KEY=

# Optional offsite backup channel
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
