# ═══════════════════════════════════════════════════════════
# Anamnesis — example environment file
# Copy to `.env` and fill in your own values.
# ═══════════════════════════════════════════════════════════

# ─── Core ───────────────────────────────────────────────────
NODE_ENV=development
PORT=3010

# ─── API tokens ─────────────────────────────────────────────
# Generate with: openssl rand -hex 32
API_TOKEN=
ADMIN_TOKEN=

# ─── CORS ───────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# In production use a strict whitelist, never `*`.
CORS_ORIGINS=http://localhost:5173

# ─── Backups ────────────────────────────────────────────────
BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=6
BACKUP_KEEP_COUNT=14

# AES-256 key for encrypted daily archives.
# Generate with: openssl rand -hex 32
# CRITICAL: store this key in a password manager, SEPARATELY from the server.
# Without it, encrypted offsite backups are unrecoverable after server loss.
BACKUP_ENCRYPTION_KEY=

# ─── Cloudflare Access (optional — outer auth gate) ────────
# Enable when the deployment sits behind Cloudflare Zero Trust → Access.
# Both must be set for CF Access JWT verification to activate; leave both
# empty for plain in-app auth only.
#   1. Cloudflare Zero Trust → Access → Applications → Add self-hosted
#   2. Application domain: anamnesis.your-domain.com
#   3. Identity providers: Google / email OTP / etc.
#   4. Policies: Include → Emails → list of friends
#   5. From the application overview page copy:
#        - Audience (AUD) tag → CF_ACCESS_AUD
#        - Team domain (https://<team>.cloudflareaccess.com) → CF_ACCESS_TEAM_DOMAIN (without https://)
CF_ACCESS_TEAM_DOMAIN=
CF_ACCESS_AUD=

# ─── Admin email (v4.1) ────────────────────────────────────
# Email который при первом CF Access login получит role='admin'
# и ai_enabled=1. Все остальные — обычные user. Никаких паролей
# хранить не надо: identity провайдер — Google через CF Access.
ANAMNESIS_ADMIN_EMAIL=

# ─── Telegram (optional — for notifications + offsite backup) ─────
# Create a bot via @BotFather, then send /start to your bot,
# then get your chat_id from https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
